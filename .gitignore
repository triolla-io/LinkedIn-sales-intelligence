# dependencies
/node_modules

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
.pnpm-debug.log*

# env files (.env.example is intentionally committed)
.env
.env.local
.env.*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# lib/generated/prisma is intentionally NOT gitignored
# Turbopack skips gitignored dirs; generated client must be visible to the bundler.
# Files are regenerated via `npm run db:gen` (also runs on postinstall).

# python (LinkedIn worker / scraper)
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# editors / OS
.idea/
.vscode/
Thumbs.db

# logs
*.log

# database backups (never commit — may contain secrets)
db-backups/

# stale prisma output (canonical client lives at lib/generated/prisma)
/app/generated/

# AI tool working directories (personal, machine-specific)
.claude/
.superpowers/

# superpowers plans & specs (keep local, new files won't be tracked)
docs/superpowers/
