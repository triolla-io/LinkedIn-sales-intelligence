generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SALESPERSON
  ADMIN
  SUPER_ADMIN
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  DISCONNECTED
}

enum Seniority {
  C_LEVEL
  VP
  DIRECTOR
  MANAGER
  IC
  OTHER
}

enum Function {
  ENGINEERING
  HR
  SALES
  MARKETING
  FINANCE
  PRODUCT
  OPERATIONS
  LEGAL
  OTHER
}

enum SyncType {
  FULL
  DELTA
  ENRICH
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PAUSED
  CANCELLED
}

enum MessageStatus {
  QUEUED
  SENT
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

// ─── NextAuth required models ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ──────────────────────────────────────────────────────

model Organization {
  id                  String   @id @default(cuid())
  name                String
  syncCadenceDays     Int      @default(3)
  monthlyApolloBudget Int      @default(500)
  createdAt           DateTime @default(now())

  users            User[]
  enrichmentSpends EnrichmentSpend[]
}

model User {
  id            String    @id @default(cuid())
  orgId         String
  email         String    @unique
  emailVerified DateTime?
  name          String
  image         String?
  role          Role      @default(SALESPERSON)
  createdAt     DateTime  @default(now())

  org             Organization      @relation(fields: [orgId], references: [id])
  accounts        Account[]
  sessions        Session[]
  linkedinSession LinkedinSession?
  contacts        Contact[]
  sentMessages    SentMessage[]     @relation("SentBySender")
  actedMessages   SentMessage[]     @relation("ActedByActor")
  syncJobs        SyncJob[]
  savedViews      SavedView[]
  templates       MessageTemplate[]
  auditActed      AuditEvent[]      @relation("AuditActor")
  auditTargeted   AuditEvent[]      @relation("AuditTarget")
}

model LinkedinSession {
  id              String        @id @default(cuid())
  userId          String        @unique
  encryptedCookie String
  cookieExpiresAt DateTime?
  lastValidatedAt DateTime?
  status          SessionStatus @default(DISCONNECTED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id               String     @id @default(cuid())
  ownerId          String
  linkedinUrn      String
  linkedinUrl      String
  fullName         String
  headline         String?
  currentTitle     String?
  currentCompany   String?
  currentCompanyId String?
  companySize      Int?
  seniority        Seniority?
  function         Function?
  location         String?
  industry         String?
  profilePicUrl    String?
  connectedAt      DateTime?
  lastSyncedAt     DateTime
  removedAt        DateTime?

  // enrichment
  email            String?
  phone            String?
  enrichedAt       DateTime?
  enrichmentSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages SentMessage[]

  @@unique([ownerId, linkedinUrn])
  @@index([ownerId, seniority])
  @@index([ownerId, function])
  @@index([ownerId, companySize])
  @@index([ownerId, removedAt])
  @@index([ownerId, companyId])
}

model MessageTemplate {
  id      String  @id @default(cuid())
  ownerId String
  orgId   String?
  name    String
  body    String

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages SentMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SentMessage {
  id           String        @id @default(cuid())
  senderId     String
  actorId      String
  contactId    String
  templateId   String?
  body         String
  sentAt       DateTime      @default(now())
  status       MessageStatus @default(QUEUED)
  errorMessage String?

  sender   User             @relation("SentBySender", fields: [senderId], references: [id])
  actor    User             @relation("ActedByActor", fields: [actorId], references: [id])
  contact  Contact          @relation(fields: [contactId], references: [id])
  template MessageTemplate? @relation(fields: [templateId], references: [id])

  @@index([senderId, sentAt])
  @@index([contactId])
}

model SyncJob {
  id             String    @id @default(cuid())
  userId         String
  type           SyncType
  status         JobStatus @default(QUEUED)
  totalItems     Int?
  processedItems Int       @default(0)
  startedAt      DateTime?
  finishedAt     DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model SavedView {
  id         String   @id @default(cuid())
  ownerId    String
  orgId      String?
  name       String
  filterJson Json
  createdAt  DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id           String   @id @default(cuid())
  actorId      String
  targetUserId String?
  action       String
  payload      Json
  createdAt    DateTime @default(now())

  actor  User  @relation("AuditActor", fields: [actorId], references: [id])
  target User? @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId])
  @@index([actorId])
  @@index([createdAt])
}

model EnrichmentSpend {
  id      String @id @default(cuid())
  orgId   String
  month   String // "YYYY-MM"
  credits Int    @default(0)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, month])
}

model Company {
  id             String    @id @default(cuid())
  universalName  String    @unique // slug used to look up via Voyager (e.g. "microsoft")
  name           String
  industry       String?
  staffCount     Int? // exact headcount from Voyager (e.g. 231227)
  website        String?
  description    String?   @db.Text
  lastEnrichedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contacts Contact[]

  @@index([industry])
  @@index([staffCount])
}
