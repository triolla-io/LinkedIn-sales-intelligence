# ─── Database ───────────────────────────────────────────────────────────────
# Get a free Neon Postgres DB at https://neon.tech
# Docker local dev (docker compose up -d) uses port 5433 to avoid conflicts:
# DATABASE_URL="postgresql://linkedinsi:linkedinsi@localhost:5433/linkedinsi"
# For Neon:
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── App auth ────────────────────────────────────────────────────────────────
# Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Inngest ─────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Apollo.io ───────────────────────────────────────────────────────────────
APOLLO_API_KEY=""

# ─── HubSpot ──────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=""

# ─── Apollo mobile webhook (optional) ────────────────────────────────────────
# Set ENABLE_APOLLO_MOBILE_WEBHOOK=true to fire a second Apollo request for
# mobile phones. Apollo will call APOLLO_WEBHOOK_URL with the result async.
# In local dev: run `ngrok http 3000` and set APOLLO_WEBHOOK_URL accordingly.
# APOLLO_WEBHOOK_SECRET=""
# APOLLO_WEBHOOK_URL=""
# ENABLE_APOLLO_MOBILE_WEBHOOK=""

# ─── LinkedIn cookie encryption ──────────────────────────────────────────────
# 32 random bytes, base64-encoded: `openssl rand -base64 32`
LINKEDIN_COOKIE_ENC_KEY=""

# ─── Browserless (for LinkedIn login iframe) ─────────────────────────────────
# Get a token at https://www.browserless.io or https://www.browserbase.com
BROWSERLESS_TOKEN=""
BROWSERLESS_ENDPOINT="wss://chrome.browserless.io"

# ─── Upstash Redis (rate-limiting) ───────────────────────────────────────────
# Provision at https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── LinkedIn company enrichment ─────────────────────────────────────────────
# Path to the linkedin-mcp Chromium profile (holds li_at + JSESSIONID).
LINKEDIN_PROFILE_DIR=~/.linkedin-mcp/profile

# Resend API key for sending invite emails (https://resend.com — free tier available)
# Without this, invite links are shown on screen instead of emailed.
RESEND_API_KEY=

# Google Gemini API key — for company enrichment via Google Search grounding.
# Free tier: 1,500 requests/day. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic API key — for Hebrew name and company size enrichment via Claude Haiku.
# Get a key at https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ─── WhatsApp service ─────────────────────────────────────────────────────────
# URL of the whatsapp-service sidecar. Defaults to http://localhost:3002.
# In docker-compose production deployments this is set to http://whatsapp-service:3002
# via the compose file — no need to set it manually there.
WHATSAPP_SERVICE_URL=http://localhost:3002
